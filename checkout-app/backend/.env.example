# ─── MongoDB ──────────────────────────────────────────────
# For local MongoDB: mongodb://localhost:27017/checkout_app
# For MongoDB Atlas: mongodb+srv://<user>:<pass>@cluster.mongodb.net/checkout_app
MONGO_URI=mongodb://localhost:27017/checkout_app

# ─── JWT ──────────────────────────────────────────────────
# Generate a strong random secret: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
JWT_EXPIRES_IN=7d

# ─── Stripe ───────────────────────────────────────────────
# Get these from https://dashboard.stripe.com/test/apikeys
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here

# ─── Server ───────────────────────────────────────────────
PORT=5000
NODE_ENV=development
CLIENT_URL=http://localhost:3000
