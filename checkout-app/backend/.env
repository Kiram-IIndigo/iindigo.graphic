# ─── MongoDB ──────────────────────────────────────────────
# For local MongoDB: mongodb://localhost:27017/checkout_app
# For MongoDB Atlas: mongodb+srv://<user>:<pass>@cluster.mongodb.net/checkout_app
MONGO_URI=mongodb://localhost:27017/checkout_app

# ─── JWT ──────────────────────────────────────────────────
# Generate a strong random secret: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
JWT_EXPIRES_IN=7d

